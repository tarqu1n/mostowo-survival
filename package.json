{
  "name": "mostowo-survival",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser pixel-art survival base-builder themed around Mostowo (Phaser 3).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "gen:retrodiffusion": "node scripts/gen-art/retrodiffusion.mjs",
    "gen:pixellab": "node scripts/gen-art/pixellab.mjs"
  },
  "dependencies": {
    "phaser": "^3.88.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
