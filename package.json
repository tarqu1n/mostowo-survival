{
  "name": "mostowo-survival",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser pixel-art survival base-builder themed around Mostowo (Phaser 3).",
  "scripts": {
    "dev": "vite",
    "editor": "vite --open /editor.html",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run lint:md && npm run format:check && npm run test",
    "e2e": "playwright test",
    "smoke": "node scripts/smoke.mjs",
    "assets:catalog": "node scripts/asset-catalog.mjs",
    "gen:retrodiffusion": "node scripts/gen-art/retrodiffusion.mjs",
    "gen:pixellab": "node scripts/gen-art/pixellab.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "phaser": "^3.88.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "markdownlint-cli2": "^0.23.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2 --fix"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  }
}
