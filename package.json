{
  "name": "mostowo-survival",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Browser pixel-art survival base-builder themed around Mostowo (Phaser 3).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run test",
    "e2e": "playwright test",
    "smoke": "node scripts/smoke.mjs",
    "gen:retrodiffusion": "node scripts/gen-art/retrodiffusion.mjs",
    "gen:pixellab": "node scripts/gen-art/pixellab.mjs"
  },
  "dependencies": {
    "eventemitter3": "^5.0.4",
    "phaser": "^3.88.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.7"
  }
}
